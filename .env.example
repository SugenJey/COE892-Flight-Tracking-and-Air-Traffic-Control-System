# Local development — copy to .env and fill in your values
# Cloud Run: set these as env vars in cloudbuild.yaml substitutions

# MySQL connection (local TCP — used when INSTANCE_CONNECTION_NAME is not set)
DB_USER=root
DB_PASS=yourpassword
DB_NAME=atc_db
DB_HOST=127.0.0.1
DB_PORT=3306

# Cloud SQL Unix socket (Cloud Run only)
# Format: project-id:region:instance-name
INSTANCE_CONNECTION_NAME=

# RabbitMQ — sign up free at https://cloudamqp.com
# Format: amqps://user:pass@host/vhost
RABBITMQ_URL=
